DEEPSEEK_API_KEY=

# Scrapling MCP (scraping web / Playwright). Independiente de Google Places.
# Variable correcta: SCRAPLING_MCP_URL (con S al inicio).
SCRAPLING_MCP_URL=http://52.15.192.69:8000/mcp

# Microservicio del partner que enriquece leads (find_business_partner).
# Recibe { nicho, zona, candidates: Lead[] } y responde { results: Lead[] enriquecidos }.
# Reemplaza la llamada directa a Google Places.
PARTNER_SCRAPER_URL=
