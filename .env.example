DEEPSEEK_API_KEY=

# Scrapling MCP (scraping web / Playwright). Independiente de Google Places.
# Variable correcta: SCRAPLING_MCP_URL (con S al inicio).
SCRAPLING_MCP_URL=http://52.15.192.69:8000/mcp

# Microservicio del partner que enriquece leads (find_business_partner).
# Recibe { nicho, zona, candidates: Lead[] } y responde { results: Lead[] enriquecidos }.
# Reemplaza la llamada directa a Google Places.
PARTNER_SCRAPER_URL=
# Opcional: token Bearer si el partner requiere auth.
PARTNER_SCRAPER_TOKEN=

# Tras find_business_partner, perfilamiento de prospectos (POST /analyze).
# Por defecto: https://gtm-insights-module-production.up.railway.app/analyze
# GTM_INSIGHTS_ANALYZE_URL=false  → no llamar al módulo
# GTM_INSIGHTS_ANALYZE_TOKEN=     → Bearer opcional
# GTM_PRODUCT_NAME=               → nombre corto en product_context (opcional)
# GTM_PRODUCT_PRICE_RANGE=mid     → low | mid | high (opcional)
GTM_INSIGHTS_ANALYZE_URL=
GTM_INSIGHTS_ANALYZE_TOKEN=

PORT=3001

# ElevenLabs — voz TTS para Gotom (POST /api/tts)
ELEVENLABS_API_KEY=
# Opcional: ID de voz en ElevenLabs (por defecto voz multilingüe tipo Bella)
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
